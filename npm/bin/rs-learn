#!/usr/bin/env node
'use strict';
const { spawn } = require('child_process');
const { ensureBinary } = require('../install');

(async () => {
  let bin;
  try {
    bin = await ensureBinary({ verbose: false });
  } catch (e) {
    console.error(`rs-learn: failed to obtain binary: ${e.message}`);
    console.error('rs-learn: check network connectivity and that a release exists for this version.');
    process.exit(1);
  }
  const child = spawn(bin, process.argv.slice(2), { stdio: 'inherit' });
  child.on('exit', code => process.exit(code ?? 1));
  child.on('error', err => { console.error(`rs-learn: spawn failed: ${err.message}`); process.exit(1); });
})();
